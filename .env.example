# Lennarts Diktat-Trainer — Umgebungsvariablen
# Kopiere diese Datei als .env und trage echte Werte ein.
# NIEMALS die .env mit echten Keys committen!

# Pflichtfeld: zufälliger, langer String (min. 32 Zeichen)
# Generieren z.B. mit: php -r "echo bin2hex(random_bytes(32));"
APP_ENCRYPTION_KEY=BITTE_AENDERN_min32zeichen_random

# Optionaler App-Name (für den Seitentitel)
APP_NAME="Lennarts Diktat-Trainer"

# Umgebung: production | development
APP_ENV=production
